{
  "name": "@quickdeployai/workflows-registry-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "QuickDeployAI Workflows Registry workspace",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check": "turbo run build typecheck lint test && pnpm registry:validate && pnpm registry:build:check",
    "registry:validate": "pnpm --filter @quickdeployai/workflows-cli registry:validate",
    "registry:build": "pnpm --filter @quickdeployai/workflows-cli build:registry",
    "registry:build:check": "pnpm --filter @quickdeployai/workflows-cli check:generated"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@quickdeployai/workflows-cli": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "supportedArchitectures": {
      "os": ["win32", "linux", "darwin"],
      "cpu": ["x64", "arm64"]
    }
  }
}

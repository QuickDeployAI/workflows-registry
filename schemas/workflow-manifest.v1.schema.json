{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://quickdeploy.ai/schemas/workflow-manifest.v1.schema.json",
  "title": "QuickDeploy WorkflowManifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "quickdeploy.ai/v1" },
    "kind": { "const": "WorkflowManifest" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "pattern": "^ai\\.quickdeploy/[A-Za-z0-9._-]+$" },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
        },
        "title": { "type": "string", "maxLength": 100 },
        "description": { "type": "string", "maxLength": 100 },
        "labels": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["importer", "source"],
      "properties": {
        "importer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["engine"],
          "properties": {
            "engine": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*-2-workflows$" },
            "versionRange": { "type": "string", "minLength": 1 }
          }
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "uri"],
          "properties": {
            "type": { "enum": ["http", "file", "git", "oci"] },
            "uri": { "type": "string", "minLength": 1 },
            "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
            "ref": { "type": "string", "minLength": 1 }
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "enum": ["http", "oci"] } } },
              "then": { "required": ["digest"] }
            },
            {
              "if": { "properties": { "type": { "const": "git" } } },
              "then": {
                "anyOf": [
                  { "required": ["digest"] },
                  {
                    "required": ["ref"],
                    "properties": {
                      "ref": { "pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$" }
                    }
                  }
                ]
              }
            }
          ]
        },
        "entrypoint": { "type": "string", "minLength": 1 },
        "config": { "type": "object" },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "env": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
                  "description": { "type": "string", "maxLength": 200 },
                  "secret": { "type": "boolean" }
                }
              }
            }
          }
        },
        "budgets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "maxIterations": { "type": "integer", "minimum": 1 },
            "maxParallelism": { "type": "integer", "minimum": 1 },
            "maxDepth": { "type": "integer", "minimum": 1 },
            "maxChildren": { "type": "integer", "minimum": 1 }
          }
        },
        "output": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path"],
          "properties": {
            "path": { "type": "string", "pattern": "^workflows/[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*$" }
          }
        }
      }
    },
    "_meta": { "type": "object" }
  }
}

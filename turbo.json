{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "packages/core/workspace-config/**",
    "eslint.config.mjs",
    "pnpm-workspace.yaml"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build", "^build"],
      "outputs": []
    }
  }
}

{
  "name": "@quickdeployai/workflows-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Build, validate, import, compile, and run QuickDeploy workflows-registry artifacts.",
  "bin": {
    "workflows-cli": "./src/cli.mts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "start": "tsx src/cli.mts",
    "build:registry": "tsx src/cli.mts build",
    "check:generated": "tsx src/cli.mts build --check",
    "validate": "tsx src/cli.mts validate",
    "registry:validate": "tsx src/cli.mts validate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@quickdeployai/arazzo-2-workflows": "workspace:*",
    "@quickdeployai/pi-agents-2-workflows": "workspace:*",
    "@quickdeployai/plan-interpreter": "workspace:*",
    "@quickdeployai/serverless-workflow-2-workflows": "workspace:*",
    "@quickdeployai/workflow-capabilities": "workspace:*",
    "@quickdeployai/workflow-core": "workspace:*",
    "@quickdeployai/workflow-expressions": "workspace:*",
    "@quickdeployai/workflow-importer-kit": "workspace:*",
    "@quickdeployai/workflow-ir": "workspace:*",
    "@quickdeployai/workflow-policy": "workspace:*",
    "@quickdeployai/workflow-registry-schemas": "workspace:*",
    "@workflow/vitest": "catalog:",
    "workflow": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@quickdeployai/workflows-registry-workspace-config": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.18"
  }
}
